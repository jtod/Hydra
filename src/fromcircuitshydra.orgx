**** Laws of Boolean algebra
#+BEGIN_EXAMPLE

\begin{table}
  \caption{Laws of Boolean algebra}
  \label{tbl:laws-Boolean-algebra}
  \hrule
  \begin{center}
    \begin{minipage}{8cm}
      \begin{align}
        \intertext{\textbf{Identity}}
        % Identities
        a \vee 0   &= a   \label{eqn:or-identity}\\
        a \wedge 1 &= a \\
        \intertext{\textbf{Annihilator}}
        x \wedge 0 &= 0 \\
        x \vee 1 &= 1
        \intertext{\textbf{Complement}}
        a \wedge (\neg a) &= 0\\
        a \wedge \neg a &= 0 \\
        a \vee \neg a &= 1 \\
        \noindent\intertext{\textbf{Commutative}}
        a \vee b   &= b \vee a \\
        a \wedge b &= b \wedge a \\
        \intertext{\textbf{Associative}}
        (a \vee b) \vee c     &= a \vee (b \vee c) \\
        (a \wedge b) \wedge c &= a \wedge (b \wedge c) \\
        \intertext{\textbf{Distributive}}
        a \wedge (b \vee c) &= (a \wedge b) \vee (a \wedge c) \\
        a \vee (b \wedge c) &= (a \vee b) \wedge (a \vee c)
      \end{align}
    \end{minipage}
  \end{center}
  \hrule
\end{table}

#+BEGIN_SRC sigma


