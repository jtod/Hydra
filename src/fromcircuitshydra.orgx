  = inv a

#+END_SRC

\begin{theorem}
$a \wedge a = a$
\end{theorem}

\begin{lemma}
$a \vee a = a$
\begin{proof}
Because I say.
\end{proof}
\end{lemma}
#+END_EXAMPLE


See \ref{eqn:or-identity} for identity on or.

